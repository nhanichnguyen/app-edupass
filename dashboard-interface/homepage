function sendUserMsg(chipEl, forcedMsg) {
  const input = document.getElementById('chatInputField');
  const msg = forcedMsg || (chipEl ? chipEl.textContent.trim() : input.value.trim());
  if (!msg || chatTyping) return;

  const area = document.getElementById('chatArea');
  const chips = document.getElementById('quickChips');

  // Remove chips
  chips.innerHTML = '';

  // Append user bubble
  const uBubble = document.createElement('div');
  uBubble.style.alignSelf = 'flex-end';
  uBubble.innerHTML = `<div class="bubble bubble-user">${msg}</div>`;
  area.appendChild(uBubble);
  area.scrollTop = area.scrollHeight;
  input.value = '';

  // Typing indicator
  chatTyping = true;
  const typing = document.createElement('div');
  typing.style.alignSelf = 'flex-start';
  typing.innerHTML = `<div class="bubble-label">EDUBOT</div><div class="bubble bubble-ai"><span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span></div>`;
  area.appendChild(typing);
  area.scrollTop = area.scrollHeight;

  const script = chatScript[msg] || chatScript['default'];
  setTimeout(() => {
    area.removeChild(typing);
    const aiBubble = document.createElement('div');
    aiBubble.style.alignSelf = 'flex-start';
    aiBubble.innerHTML = `<div class="bubble-label">EDUBOT</div><div class="bubble bubble-ai" style="animation:fadeUp .25s ease both">${script.reply}</div>`;
    area.appendChild(aiBubble);
    area.scrollTop = area.scrollHeight;
    chatTyping = false;

    if (script.chips) {
      const newChips = document.createElement('div');
      newChips.className = 'chips';
      script.chips.forEach(c => {
        const ch = document.createElement('div');
        ch.className = 'chip';
        ch.textContent = c;
        ch.onclick = () => sendUserMsg(null, c);
        newChips.appendChild(ch);
      });
      chips.appendChild(newChips);
    }
    if (script.action) script.action();
  }, 1600);
}
function sendChat() { sendUserMsg(null, document.getElementById('chatInputField').value.trim()); }

/* ── ANONYMOUS TEACHER CHAT ── */
