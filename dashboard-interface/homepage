<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EduPass — Siêu Ứng Dụng Giáo Dục Quốc Gia</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&family=Lexend+Deca:wght@700;800;900&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════
   DESIGN TOKENS — LIGHT THEME
═══════════════════════════════════════ */
:root {
  --bg:        #F0F4F8;
  --bg-2:      #E8EDF5;
  --surface:   #FFFFFF;
  --surface-2: #F7F9FC;
  --border:    #DDE3EE;
  --border-2:  #C8D1E0;

  --green:     #1A7A4A;
  --green-mid: #22A55E;
  --green-lt:  #D6F0E2;
  --green-bg:  #EBF7F1;

  --navy:      #1C2B4A;
  --navy-mid:  #2D4070;
  --navy-lt:   #E8ECF6;

  --amber:     #B45309;
  --amber-mid: #D97706;
  --amber-lt:  #FEF3C7;
  --amber-bg:  #FFFBEB;

  --red:       #B91C1C;
  --red-mid:   #DC2626;
  --red-lt:    #FEE2E2;
  --red-bg:    #FFF5F5;

  --blue:      #1D4ED8;
  --blue-mid:  #3B82F6;
  --blue-lt:   #DBEAFE;
  --blue-bg:   #EFF6FF;

  --purple:    #6D28D9;
  --purple-lt: #EDE9FE;

  --text-1:    #1C2B4A;
  --text-2:    #4A5568;
  --text-3:    #8896A9;
  --text-inv:  #FFFFFF;

  --sidebar-w: 256px;
  --topbar-h:  60px;
  --r:         12px;
  --r-sm:      8px;
  --r-lg:      18px;

  --shadow-sm: 0 1px 3px rgba(28,43,74,.07), 0 1px 2px rgba(28,43,74,.04);
  --shadow:    0 4px 12px rgba(28,43,74,.08), 0 2px 4px rgba(28,43,74,.05);
  --shadow-lg: 0 12px 32px rgba(28,43,74,.12), 0 4px 8px rgba(28,43,74,.07);
}

/* ═══════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════ */
*{margin:0;padding:0;box-sizing:border-box;}
html{font-size:15px;scroll-behavior:smooth;}
body{
  font-family:'Be Vietnam Pro',sans-serif;
  background:var(--bg);
  color:var(--text-1);
  min-height:100vh;
  overflow-x:hidden;
  line-height:1.5;
}
button{font-family:inherit;cursor:pointer;}
input,textarea,select{font-family:inherit;}

/* ═══════════════════════════════════════
   LAYOUT
═══════════════════════════════════════ */
.shell{display:flex;min-height:100vh;}

/* ═══════════════════════════════════════
   SIDEBAR
═══════════════════════════════════════ */
.sidebar{
  width:var(--sidebar-w);
  background:var(--surface);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  position:fixed;top:0;left:0;bottom:0;z-index:200;
  overflow-y:auto;overflow-x:hidden;
}
.sidebar::-webkit-scrollbar{width:4px;}
.sidebar::-webkit-scrollbar-thumb{background:var(--border-2);border-radius:99px;}

.sb-brand{
  padding:20px 18px 16px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:10px;
  position:sticky;top:0;background:var(--surface);z-index:10;
}
.sb-logo{
  width:36px;height:36px;border-radius:10px;
  background:linear-gradient(135deg,var(--green),var(--green-mid));
  display:flex;align-items:center;justify-content:center;
  font-family:'Lexend Deca',sans-serif;font-size:0.82rem;font-weight:900;
  color:#fff;letter-spacing:-0.5px;flex-shrink:0;
  box-shadow:0 4px 12px rgba(26,122,74,.3);
}
.sb-name{font-family:'Lexend Deca',sans-serif;font-size:1.08rem;font-weight:900;color:var(--navy);letter-spacing:-0.3px;}
.sb-tag{font-size:0.6rem;color:var(--text-3);letter-spacing:.06em;text-transform:uppercase;font-weight:600;display:block;}

.sb-section{
  font-size:.6rem;font-weight:800;letter-spacing:.1em;
  text-transform:uppercase;color:var(--text-3);
  padding:14px 18px 5px;
}

.nav-item{
  display:flex;align-items:center;gap:9px;
  padding:8px 18px;margin:1px 8px;border-radius:var(--r-sm);
  cursor:pointer;color:var(--text-2);font-size:.82rem;font-weight:500;
  transition:all .16s;user-select:none;border:none;background:transparent;
  text-align:left;width:calc(100% - 16px);
}
.nav-item:hover{background:var(--bg);color:var(--text-1);}
.nav-item.active{background:var(--green-bg);color:var(--green);font-weight:700;}
.nav-item.active .nav-icon{color:var(--green);}
.nav-icon{font-size:.95rem;width:18px;text-align:center;flex-shrink:0;}
.nav-badge{
  margin-left:auto;padding:2px 7px;border-radius:99px;
  font-size:.58rem;font-weight:800;letter-spacing:.02em;
}
.badge-red{background:var(--red-lt);color:var(--red);}
.badge-green{background:var(--green-lt);color:var(--green);}
.badge-amber{background:var(--amber-lt);color:var(--amber);}
.badge-blue{background:var(--blue-lt);color:var(--blue);}

.sb-user{
  margin-top:auto;padding:14px 18px;
  border-top:1px solid var(--border);
  display:flex;align-items:center;gap:10px;
  position:sticky;bottom:0;background:var(--surface);
}
.sb-avatar{
  width:34px;height:34px;border-radius:50%;
  background:linear-gradient(135deg,var(--navy-mid),var(--green));
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:.75rem;color:#fff;flex-shrink:0;
}
.sb-user-name{font-size:.8rem;font-weight:700;color:var(--text-1);}
.sb-user-role{font-size:.65rem;color:var(--text-3);}

/* ═══════════════════════════════════════
   MAIN
═══════════════════════════════════════ */
.main{margin-left:var(--sidebar-w);flex:1;display:flex;flex-direction:column;min-height:100vh;}

/* TOPBAR */
.topbar{
  height:var(--topbar-h);
  background:var(--surface);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:12px;
  padding:0 28px;
  position:sticky;top:0;z-index:100;
  box-shadow:var(--shadow-sm);
}
.topbar-breadcrumb{
  display:flex;align-items:center;gap:6px;
  font-size:.78rem;color:var(--text-3);
}
.topbar-breadcrumb .current{color:var(--text-1);font-weight:700;}
.topbar-sep{color:var(--border-2);}

.topbar-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.topbar-search{
  display:flex;align-items:center;gap:7px;
  background:var(--bg);border:1px solid var(--border);
  border-radius:99px;padding:7px 14px;
  font-size:.78rem;color:var(--text-3);cursor:text;
  transition:.2s;width:180px;
}
.topbar-search:hover{border-color:var(--border-2);background:var(--surface);}
.topbar-btn{
  width:34px;height:34px;border-radius:50%;
  background:var(--bg);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:.92rem;transition:.2s;position:relative;
}
.topbar-btn:hover{background:var(--surface);box-shadow:var(--shadow-sm);}
.notif-dot{
  position:absolute;top:5px;right:5px;
  width:7px;height:7px;background:var(--red-mid);
  border-radius:50%;border:1.5px solid var(--surface);
}
.topbar-avatar{
  width:34px;height:34px;border-radius:50%;
  background:linear-gradient(135deg,var(--navy-mid),var(--green));
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:.72rem;color:#fff;cursor:pointer;
  box-shadow:var(--shadow-sm);
}

/* ═══════════════════════════════════════
   PAGE AREA
═══════════════════════════════════════ */
.page{display:none;padding:24px 28px 48px;animation:fadeUp .28s ease both;}
.page.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

.page-header{margin-bottom:22px;}
.page-title{
  font-family:'Lexend Deca',sans-serif;
  font-size:1.45rem;font-weight:900;color:var(--navy);letter-spacing:-.3px;
}
.page-sub{font-size:.82rem;color:var(--text-3);margin-top:3px;}

/* ═══════════════════════════════════════
   CARDS
═══════════════════════════════════════ */
.card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--r);padding:20px;
  box-shadow:var(--shadow-sm);transition:.2s;
}
.card:hover{box-shadow:var(--shadow);}
.card-title{font-weight:800;font-size:.9rem;color:var(--text-1);}
.card-sub{font-size:.75rem;color:var(--text-3);margin-top:3px;}

/* ═══════════════════════════════════════
   GRID
═══════════════════════════════════════ */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.g1-2{display:grid;grid-template-columns:1fr 2fr;gap:16px;}
.g2-1{display:grid;grid-template-columns:2fr 1fr;gap:16px;}

/* ═══════════════════════════════════════
   STAT CARDS
═══════════════════════════════════════ */
.stat{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--r);padding:18px 20px;box-shadow:var(--shadow-sm);
}
.stat-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-3);margin-bottom:6px;}
.stat-val{font-family:'Lexend Deca',sans-serif;font-size:2rem;font-weight:900;line-height:1;color:var(--navy);}
.stat-unit{font-size:.7rem;color:var(--text-3);margin-top:3px;}
.stat-tag{display:inline-flex;align-items:center;gap:4px;font-size:.68rem;font-weight:700;padding:3px 8px;border-radius:99px;margin-top:8px;}
.t-up{background:var(--green-lt);color:var(--green);}
.t-warn{background:var(--amber-lt);color:var(--amber);}
.t-down{background:var(--red-lt);color:var(--red);}
.t-blue{background:var(--blue-lt);color:var(--blue);}

/* ═══════════════════════════════════════
   PILLS & BADGES
═══════════════════════════════════════ */
.pill{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:99px;font-size:.68rem;font-weight:700;}
.p-green{background:var(--green-lt);color:var(--green);}
.p-amber{background:var(--amber-lt);color:var(--amber);}
.p-red{background:var(--red-lt);color:var(--red);}
.p-blue{background:var(--blue-lt);color:var(--blue);}
.p-navy{background:var(--navy-lt);color:var(--navy-mid);}
.p-purple{background:var(--purple-lt);color:var(--purple);}
.p-gray{background:var(--bg-2);color:var(--text-3);}

/* ═══════════════════════════════════════
   BUTTONS
═══════════════════════════════════════ */
.btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:9px 18px;border-radius:99px;border:none;
  font-size:.8rem;font-weight:700;transition:.18s;cursor:pointer;
  font-family:inherit;
}
.btn-primary{background:var(--green);color:#fff;}
.btn-primary:hover{background:var(--green-mid);box-shadow:0 4px 14px rgba(26,122,74,.3);transform:translateY(-1px);}
.btn-navy{background:var(--navy);color:#fff;}
.btn-navy:hover{background:var(--navy-mid);}
.btn-amber{background:var(--amber-mid);color:#fff;}
.btn-amber:hover{background:var(--amber);}
.btn-red{background:var(--red-mid);color:#fff;}
.btn-blue{background:var(--blue);color:#fff;}
.btn-blue:hover{background:var(--blue-mid);}
.btn-outline{background:transparent;color:var(--text-2);border:1.5px solid var(--border-2);}
.btn-outline:hover{background:var(--bg);border-color:var(--border-2);color:var(--text-1);}
.btn-ghost{background:transparent;color:var(--text-3);border:none;}
.btn-ghost:hover{background:var(--bg);color:var(--text-2);}
.btn-sm{padding:6px 14px;font-size:.73rem;}
.btn-xs{padding:4px 10px;font-size:.65rem;}
.btn-icon{width:34px;height:34px;padding:0;justify-content:center;border-radius:var(--r-sm);}

/* ═══════════════════════════════════════
   PROGRESS
═══════════════════════════════════════ */
.prog{background:var(--bg-2);border-radius:99px;height:6px;overflow:hidden;}
.prog-fill{height:100%;border-radius:99px;transition:width .7s ease;}
.prog-green{background:linear-gradient(90deg,var(--green),var(--green-mid));}
.prog-amber{background:linear-gradient(90deg,var(--amber),var(--amber-mid));}
.prog-red{background:linear-gradient(90deg,var(--red),var(--red-mid));}
.prog-blue{background:linear-gradient(90deg,var(--blue),var(--blue-mid));}

/* ═══════════════════════════════════════
   DIVIDER
═══════════════════════════════════════ */
.hr{height:1px;background:var(--border);margin:16px 0;}

/* ═══════════════════════════════════════
   TABS
═══════════════════════════════════════ */
.tabs{display:flex;gap:3px;background:var(--bg);border:1px solid var(--border);border-radius:99px;padding:3px;width:fit-content;margin-bottom:20px;}
.tab{padding:7px 16px;border-radius:99px;font-size:.75rem;font-weight:600;cursor:pointer;border:none;background:transparent;color:var(--text-3);transition:.16s;}
.tab.active{background:var(--surface);color:var(--green);font-weight:800;box-shadow:var(--shadow-sm);}

/* ═══════════════════════════════════════
   ALERT BOX
═══════════════════════════════════════ */
.alert{border-radius:var(--r-sm);padding:12px 16px;display:flex;gap:10px;align-items:flex-start;}
.alert-red{background:var(--red-bg);border:1px solid rgba(185,28,28,.15);}
.alert-green{background:var(--green-bg);border:1px solid rgba(26,122,74,.15);}
.alert-amber{background:var(--amber-bg);border:1px solid rgba(180,83,9,.15);}
.alert-blue{background:var(--blue-bg);border:1px solid rgba(29,78,216,.15);}
.alert-icon{font-size:1.1rem;flex-shrink:0;margin-top:1px;}
.alert-title{font-weight:800;font-size:.82rem;color:var(--text-1);}
.alert-body{font-size:.75rem;color:var(--text-2);margin-top:2px;}

/* ═══════════════════════════════════════
   FORM ELEMENTS
═══════════════════════════════════════ */
.form-group{display:flex;flex-direction:column;gap:5px;margin-bottom:14px;}
.form-label{font-size:.75rem;font-weight:700;color:var(--text-2);}
.form-input,.form-select,.form-textarea{
  background:var(--bg);border:1.5px solid var(--border);border-radius:var(--r-sm);
  padding:10px 13px;font-size:.82rem;color:var(--text-1);outline:none;
  transition:.2s;font-family:inherit;
}
.form-input:focus,.form-select:focus,.form-textarea:focus{
  border-color:var(--green);background:var(--surface);
  box-shadow:0 0 0 3px rgba(26,122,74,.1);
}
.form-textarea{resize:vertical;min-height:90px;}

/* ═══════════════════════════════════════
   CHAT UI
═══════════════════════════════════════ */
.chat-area{display:flex;flex-direction:column;gap:12px;min-height:300px;max-height:380px;overflow-y:auto;padding:4px 0 8px;}
.chat-area::-webkit-scrollbar{width:4px;}
.chat-area::-webkit-scrollbar-thumb{background:var(--border-2);border-radius:99px;}
.bubble{max-width:76%;padding:10px 14px;border-radius:16px;font-size:.8rem;line-height:1.55;}
.bubble-ai{
  background:var(--surface);border:1px solid var(--border);
  border-bottom-left-radius:4px;align-self:flex-start;
  box-shadow:var(--shadow-sm);color:var(--text-1);
}
.bubble-user{
  background:var(--green);color:#fff;
  border-bottom-right-radius:4px;align-self:flex-end;
}
.bubble-anon{
  background:var(--navy-lt);border:1px solid rgba(28,43,74,.12);
  border-bottom-right-radius:4px;align-self:flex-end;color:var(--navy);
}
.bubble-label{font-size:.62rem;font-weight:700;color:var(--text-3);margin-bottom:3px;letter-spacing:.03em;}
.chat-input-row{display:flex;gap:8px;margin-top:12px;align-items:flex-end;}
.chat-input{
  flex:1;background:var(--bg);border:1.5px solid var(--border);border-radius:var(--r-lg);
  padding:9px 15px;font-size:.8rem;color:var(--text-1);outline:none;
  transition:.2s;font-family:inherit;resize:none;max-height:80px;
}
.chat-input:focus{border-color:var(--green);background:var(--surface);}
.chat-send{width:36px;height:36px;border-radius:50%;background:var(--green);border:none;
  color:#fff;font-size:.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:.18s;flex-shrink:0;}
.chat-send:hover{background:var(--green-mid);}
.typing-dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--text-3);margin:0 2px;animation:blink 1.2s infinite;}
.typing-dot:nth-child(2){animation-delay:.2s;}
.typing-dot:nth-child(3){animation-delay:.4s;}
@keyframes blink{0%,80%,100%{opacity:.2;}40%{opacity:1;}}

/* ═══════════════════════════════════════
   SUGGESTION CHIPS
═══════════════════════════════════════ */
.chips{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;}
.chip{
  padding:6px 13px;border-radius:99px;font-size:.72rem;font-weight:600;
  border:1.5px solid var(--border-2);background:var(--surface);color:var(--text-2);
  cursor:pointer;transition:.16s;
}
.chip:hover{border-color:var(--green);color:var(--green);background:var(--green-bg);}

/* ═══════════════════════════════════════
   TIMELINE
═══════════════════════════════════════ */
.timeline{display:flex;flex-direction:column;}
.tl-item{display:flex;gap:14px;position:relative;}
.tl-item:not(:last-child)::before{content:'';position:absolute;left:13px;top:28px;bottom:-10px;width:1px;background:var(--border);}
.tl-dot{width:26px;height:26px;border-radius:50%;background:var(--bg-2);border:2px solid var(--border);
  display:flex;align-items:center;justify-content:center;font-size:.65rem;flex-shrink:0;margin-top:2px;}
.tl-dot.done{border-color:var(--green);background:var(--green-lt);color:var(--green);}
.tl-dot.active{border-color:var(--amber-mid);background:var(--amber-lt);}
.tl-dot.pending{border-color:var(--border-2);background:var(--bg);}
.tl-body{padding-bottom:20px;}
.tl-title{font-weight:700;font-size:.82rem;color:var(--text-1);}
.tl-desc{font-size:.73rem;color:var(--text-3);margin-top:3px;line-height:1.5;}

/* ═══════════════════════════════════════
   NOTIFICATION ITEMS
═══════════════════════════════════════ */
.notif-row{display:flex;gap:12px;padding:13px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:.16s;}
.notif-row:last-child{border-bottom:none;}
.notif-row:hover{opacity:.85;}
.notif-ico{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;}
.notif-ico-r{background:var(--red-lt);}
.notif-ico-g{background:var(--green-lt);}
.notif-ico-a{background:var(--amber-lt);}
.notif-ico-b{background:var(--blue-lt);}
.notif-text{flex:1;font-size:.78rem;line-height:1.45;color:var(--text-2);}
.notif-time{font-size:.65rem;color:var(--text-3);margin-top:3px;}
.unread-dot{width:7px;height:7px;border-radius:50%;background:var(--green);margin-top:5px;flex-shrink:0;}

/* ═══════════════════════════════════════
   ROLE SWITCHER
═══════════════════════════════════════ */
.role-sw{display:flex;gap:3px;background:var(--bg);border:1px solid var(--border);border-radius:var(--r-sm);padding:3px;width:fit-content;margin-bottom:18px;}
.role-btn{padding:6px 14px;border-radius:6px;font-size:.72rem;font-weight:700;cursor:pointer;border:none;background:transparent;color:var(--text-3);transition:.15s;}
.role-btn.active{background:var(--navy);color:#fff;box-shadow:var(--shadow-sm);}

/* ═══════════════════════════════════════
   UNIVERSITY CARD
═══════════════════════════════════════ */
.uni-card{
  background:var(--surface);border:1.5px solid var(--border);
  border-radius:var(--r);padding:14px 16px;display:flex;align-items:center;gap:13px;
  cursor:pointer;transition:.18s;
}
.uni-card:hover{border-color:var(--green);box-shadow:var(--shadow);}
.uni-card.selected{border-color:var(--green);background:var(--green-bg);}
.uni-rank{
  width:42px;height:42px;border-radius:10px;background:var(--navy-lt);
  display:flex;align-items:center;justify-content:center;
  font-family:'Lexend Deca',sans-serif;font-size:1rem;font-weight:900;color:var(--navy);flex-shrink:0;
}
.uni-name{font-weight:800;font-size:.85rem;color:var(--text-1);}
.uni-code{font-size:.7rem;color:var(--text-3);}
.uni-score{
  margin-left:auto;font-family:'Lexend Deca',sans-serif;font-size:1.2rem;font-weight:900;
  color:var(--navy);flex-shrink:0;
}
.uni-score-label{font-size:.62rem;color:var(--text-3);text-align:right;}

