  const h = document.getElementById('anonTeacherHeader');
  h.innerHTML = `<div style="width:38px;height:38px;border-radius:50%;background:${color};display:flex;align-items:center;justify-content:center;font-size:1rem;color:#fff">${icon}</div><div><div style="font-weight:800;color:#fff;font-size:.85rem">Chat ẩn danh với ${name}</div><div style="font-size:.65rem;color:rgba(255,255,255,.6)">${subject} · Bạn được hiển thị là: Học sinh #A42</div></div><span class="pill" style="margin-left:auto;background:rgba(255,255,255,.15);color:#fff;font-size:.62rem">🔒 #A42</span>`;
  const area = document.getElementById('anonChatArea');
  area.innerHTML = `<div style="align-self:flex-start"><div class="bubble-label">${name.toUpperCase()}</div><div class="bubble bubble-ai">Xin chào Học sinh #A42! Tôi sẽ trả lời câu hỏi của bạn trong vòng 24h. Danh tính của bạn được bảo vệ hoàn toàn.</div></div>`;
}
function fillAnonQ(text) { document.getElementById('anonQuestionInput').value = text; }
function sendAnonQuestion() {
  const q = document.getElementById('anonQuestionInput').value.trim();
  if (!q) return showToast('Vui lòng nhập câu hỏi trước', '⚠️');
  if (!selectedTeacher) return showToast('Vui lòng chọn giáo viên trước', '⚠️');
  const area = document.getElementById('anonChatArea');
  const el = document.createElement('div');
  el.style.alignSelf = 'flex-end';
  el.innerHTML = `<div class="bubble-label" style="text-align:right">HỌC SINH #A42 (ẨN DANH)</div><div class="bubble bubble-anon">${q}</div>`;
  area.appendChild(el);
  area.scrollTop = area.scrollHeight;
  document.getElementById('anonQuestionInput').value = '';
  // Simulate teacher response
  setTimeout(() => {
    const r = document.createElement('div');
    r.style.alignSelf = 'flex-start';
    r.innerHTML = `<div class="bubble-label">${selectedTeacher.name.toUpperCase()}</div><div class="bubble bubble-ai"><span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span></div>`;
    area.appendChild(r);
    area.scrollTop = area.scrollHeight;
    setTimeout(() => {
      r.innerHTML = `<div class="bubble-label">${selectedTeacher.name.toUpperCase()}</div><div class="bubble bubble-ai" style="animation:fadeUp .25s both">Cảm ơn bạn đã đặt câu hỏi! Câu hỏi rất hay — tôi sẽ trả lời chi tiết trong tiết học sắp tới và cũng gửi phản hồi qua hệ thống này trong 24h. Nếu cần gấp, bạn có thể tham khảo tài liệu bổ trợ trong thư mục môn học. 📚</div>`;
      showToast('Đã gửi câu hỏi ẩn danh tới ' + selectedTeacher.name, '📤');
    }, 2000);
  }, 500);
}

/* ── SỔ LIÊN LẠC ── */
function switchRole(role, btn) {
  document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const labels = {student:'Học sinh',parent:'Phụ huynh',teacher:'Giáo viên',school:'Nhà trường'};
  document.getElementById('roleLabel').textContent = labels[role] || role;
  showToast('Đang xem với vai trò: ' + labels[role], '👤');
}
function openThread(name, subject, type, color, icon, lastMsg, time) {
  document.getElementById('threadDetailHeader').innerHTML = `<div style="width:38px;height:38px;border-radius:50%;background:${color};display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:#fff">${icon}</div><div><div style="font-weight:800;color:#fff;font-size:.88rem">${name}</div><div style="font-size:.68rem;color:rgba(255,255,255,.6)">${subject}</div></div><span style="margin-left:auto;font-size:.65rem;color:rgba(255,255,255,.5)">${time}</span>`;
  document.getElementById('threadMessages').innerHTML = `
    <div class="chat-area" style="min-height:200px;max-height:280px">
      <div style="align-self:flex-start">
        <div class="bubble-label">${name.toUpperCase()}</div>
        <div class="bubble bubble-ai">${lastMsg}</div>
      </div>
    </div>
    <div style="display:flex;gap:8px;margin-top:12px">
      <div class="bubble bubble-user" style="font-size:.75rem;opacity:.7">Dạ em cảm ơn ạ, em sẽ sắp xếp thời gian gặp cô.</div>
    </div>`;
  openModal('modal-thread');
}

/* ── NGUYỆN VỌNG ĐH ── */
function removeSlot(num) {
  const slot = document.getElementById('slot' + num);
  slot.className = 'slot mb-10';
  slot.innerHTML = `<div class="slot-num">${num}</div><div style="flex:1;color:var(--text-3)"><div style="font-size:.82rem;font-weight:600">+ Thêm Nguyện vọng ${num}</div><div class="f-xs">Nhấn để chọn trường</div></div><button class="btn btn-primary btn-xs" onclick="openModal('modal-uni-search')">Chọn</button>`;
  slot.style.cursor = 'pointer';
  slot.onclick = () => openModal('modal-uni-search');
  showToast('Đã xóa nguyện vọng ' + num, '✕');
}
function fillSlot3(el, major, uni, code, score, chance) {
  const slot = document.getElementById('slot3');
